{
  "baseBranch": "main",
  "access": "public",
  "changelog": "github",
  "privatePackages": {
    "version": true,
    "tag": false
  },
  "aggregateRelease": {
    "enabled": true,
    "title": "portwatch"
  },
  "changedFilePatterns": ["**"],
  "versionPr": {
    "title": "Version Packages",
    "branch": "bumpy/version-packages"
  },
  "packages": {
    "portwatcher": {
      "managed": true,
      "skipNpmPublish": true,
      "publishCommand": "git tag \"v$(node -p \\\"require('./package.json').version\\\")\" && git push origin \"v$(node -p \\\"require('./package.json').version\\\")\"",
      "changedFilePatterns": ["**"]
    }
  },
  "allowCustomCommands": false
}
