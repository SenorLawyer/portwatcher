{
  "baseBranch": "main",
  "access": "public",
  "changelog": "github",
  "privatePackages": {
    "version": true,
    "tag": false
  },
  "aggregateRelease": {
    "enabled": true,
    "title": "portwatch"
  },
  "changedFilePatterns": ["**"],
  "versionPr": {
    "title": "Version Packages",
    "branch": "bumpy/version-packages"
  },
  "packages": {
    "portwatcher": {
      "managed": true,
      "skipNpmPublish": true,
      "publishCommand": "git rev-parse \"v{{version}}\" >/dev/null 2>&1 || git tag \"v{{version}}\"",
      "changedFilePatterns": ["**"]
    }
  },
  "allowCustomCommands": false
}
